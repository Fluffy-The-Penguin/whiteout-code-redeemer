DISCORD_TOKEN=your_bot_token_here

# Bot checks every 5-10 minutes by default, matching the original bot behavior.
CHECK_INTERVAL_MIN_MS=300000
CHECK_INTERVAL_MAX_MS=600000

# false = first startup records currently known codes and waits for future new codes.
# true = first startup also redeems existing fetched codes.
REDEEM_EXISTING_ON_START=false
